  "glossCoinTerm": "CareCoin (cc)",
  "@glossCoinTerm": { "description": "Glossary term" },
  "glossCoinDef": "The family's own currency. Coins have no real-money value: they make contribution visible and buy rewards in your family's store.",
  "@glossCoinDef": { "description": "Glossary definition" },
  "glossBudgetTerm": "Monthly budget",
  "@glossBudgetTerm": { "description": "Glossary term" },
  "glossBudgetDef": "Each month the family pool (1,000 cc by default) is allocated. Task coin values draw from it — the Budget gauge in Activities shows what's left.",
  "@glossBudgetDef": { "description": "Glossary definition" },
  "glossTemplateTerm": "Template vs. scheduled task",
  "@glossTemplateTerm": { "description": "Glossary term" },
  "glossTemplateDef": "A template describes a job: title, duration, coin value. Scheduling places a copy of it on a specific day and time.",
  "@glossTemplateDef": { "description": "Glossary definition" },
  "glossValidationTerm": "Validation",
  "@glossValidationTerm": { "description": "Glossary term" },
  "glossValidationDef": "After someone marks a task done, a caregiver confirms it. Only then do the coins land in the earner's wallet.",
  "@glossValidationDef": { "description": "Glossary definition" },
  "glossBountyTerm": "Bounty",
  "@glossBountyTerm": { "description": "Glossary term" },
  "glossBountyDef": "Bonus coins a caregiver attaches to a task to make it more attractive. Whoever takes the task over earns the bonus on completion.",
  "@glossBountyDef": { "description": "Glossary definition" },
  "glossObjectTerm": "Object of care",
  "@glossObjectTerm": { "description": "Glossary term" },
  "glossObjectDef": "Someone (or something) you care for who doesn't use the app themselves: a child, an elderly relative, a pet.",
  "@glossObjectDef": { "description": "Glossary definition" },
  "glossLedgerTerm": "Ledger",
  "@glossLedgerTerm": { "description": "Glossary term" },
  "glossLedgerDef": "The record of every coin earned and spent. A caregiver can revert an entry from the Personal Area if something was validated by mistake.",
  "@glossLedgerDef": { "description": "Glossary definition" },

  "faqCoinsQ": "Where do coins come from?",
  "@faqCoinsQ": { "description": "FAQ question" },
  "faqCoinsA": "From the family's monthly budget. Once a month the pool is distributed, and every task you define carries a value paid out of it. Nothing is bought with real money.",
  "@faqCoinsA": { "description": "FAQ answer" },
  "faqApprovalQ": "Why does a new activity need approval?",
  "@faqApprovalQ": { "description": "FAQ question" },
  "faqApprovalA": "Caregivers review new tasks before they enter the catalogue so coin values stay fair. You'll find pending ones in the Activities tab.",
  "@faqApprovalA": { "description": "FAQ answer" },
  "faqCompletedQ": "Why can't I change a completed activity?",
  "@faqCompletedQ": { "description": "FAQ question" },
  "faqCompletedA": "Completed means validated and paid: the coins are already in someone's wallet. To undo one, revert its coin entry from the ledger in the Personal Area.",
  "@faqCompletedA": { "description": "FAQ answer" },
  "faqRepeatQ": "How do I make a task repeat?",
  "@faqRepeatQ": { "description": "FAQ question" },
  "faqRepeatA": "Mark it as recurring (🔁) when you create it. Then, in the Daily view, tap its card before it's validated and choose how far into the future to copy it.",
  "@faqRepeatA": { "description": "FAQ answer" },
  "faqBountyQ": "What is a bounty and how do I use one?",
  "@faqBountyQ": { "description": "FAQ question" },
  "faqBountyA": "Open a scheduled task in the Daily view and delegate it with extra coins attached. It appears under Task Offers on the Family hub until someone takes it.",
  "@faqBountyA": { "description": "FAQ answer" },
  "faqRewardsQ": "Who can create rewards?",
  "@faqRewardsQ": { "description": "FAQ question" },
  "faqRewardsA": "Caregivers, from the Rewards tab. The store is private to your family — a reward can be anything you agree is worth earning toward.",
  "@faqRewardsA": { "description": "FAQ answer" },

